# Auto-generated by install.bat — machine-specific, never commit
_env.bat

# Frontend build artefacts
# node_modules and intermediate Vite cache are excluded — they're large and reproducible.
# The compiled output in presto_geometry/web/static/ IS committed so that end users
# don't need Node.js installed.  Build once with:
#   cd frontend && npm install && npm run build
frontend/node_modules/
frontend/dist/
frontend/.vite/

# AI tool outputs — each developer keeps their own local session state
# .claude/          project-level Claude Code settings & session data
# CLAUDE.md is intentionally NOT ignored — it's shared project documentation
.claude/
.mcp.json

# Executed notebooks — cells run locally produce large embedded image outputs
# that create noisy diffs and merge conflicts; commit only the clean source
notebooks/*_executed.ipynb
notebooks/*_executed_*.ipynb
